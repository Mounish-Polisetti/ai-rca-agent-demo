{
  "title": "MLOps Model Monitoring",
  "uid": "mlops-monitoring",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "title": "BAT Model Recall",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 8 },
      "targets": [{
        "expr": "model_recall{demand_type=\"BAT\"}",
        "legendFormat": "BAT Recall"
      }],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "thresholds": {
            "steps": [
              { "value": 0,    "color": "red"    },
              { "value": 0.55, "color": "yellow" },
              { "value": 0.70, "color": "green"  }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "BAT Model Precision",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 8 },
      "targets": [{
        "expr": "model_precision{demand_type=\"BAT\"}",
        "legendFormat": "BAT Precision"
      }],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "thresholds": {
            "steps": [
              { "value": 0,    "color": "red"    },
              { "value": 0.60, "color": "yellow" },
              { "value": 0.75, "color": "green"  }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "API Latency p95 (ms)",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 8 },
      "targets": [{
        "expr": "api_latency_p95_ms",
        "legendFormat": "p95 latency"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0, "max": 1000,
          "thresholds": {
            "steps": [
              { "value": 0,   "color": "green"  },
              { "value": 300, "color": "yellow" },
              { "value": 500, "color": "red"    }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "API Error Rate",
      "type": "gauge",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 8 },
      "targets": [{
        "expr": "api_error_rate",
        "legendFormat": "Error Rate"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 0.1,
          "thresholds": {
            "steps": [
              { "value": 0,    "color": "green"  },
              { "value": 0.02, "color": "yellow" },
              { "value": 0.05, "color": "red"    }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "BAT Recall Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [{
        "expr": "model_recall{demand_type=\"BAT\"}",
        "legendFormat": "BAT Recall"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "steps": [
              { "value": 0,    "color": "red"    },
              { "value": 0.55, "color": "green"  }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Prediction Volume (BAT)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [{
        "expr": "prediction_volume{demand_type=\"BAT\"}",
        "legendFormat": "BAT Predictions/hr"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2 }
        }
      }
    }
  ]
}
